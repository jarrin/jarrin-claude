{
  "name": "jarrin-claude",
  "version": "0.1.2",
  "description": "Jarrin's version-controlled Claude Code config and the claudjar CLI",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "claudjar": "./dist/claudjar.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "claudjar": "node dist/claudjar.cjs",
    "dev": "tsx src/cli.ts",
    "build": "tsup && node scripts/build-binary.mjs",
    "build:bundle": "tsup",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "ensurepath": "node scripts/ensurepath.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@stricli/core": "^1.3.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "postject": "1.0.0-alpha.6",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
