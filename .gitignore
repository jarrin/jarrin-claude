# This repo holds ONLY hand-authored ~/.claude config, symlinked into place.
# Real secrets live in ~/.claude/ and are never copied here — but block the
# obvious by reflex, as a backstop.
*.key
*.pem
*.token
.env
.credentials.json
settings.local.json
*.log

# Backlog working state. `.claude/.jarrin.yml` is committed config and must stay
# tracked — only the transient plan/todo files below are ignored.
.claude/plans/
.claude/todo/

# Per-machine config override, merged over the committed `.jarrin.yml` by the
# claudjar CLI. Only the `worktree:` block is overridable (machine-specific dir /
# setup / copy) — never committed. Matched at any depth for nested worktrees.
.jarrin.local.yml
**/.jarrin.local.yml

# claudjar CLI build output. NOT committed — a clone must build the bundle before
# the launchers (bin/claudjar, bin/claude/session-*) can run:
#   pnpm install && pnpm build
# The launchers fail with that instruction when dist/ is missing.
dist/
node_modules/
*.tsbuildinfo
.tsup/
