# This repo holds ONLY hand-authored ~/.claude config, symlinked into place.
# Real secrets live in ~/.claude/ and are never copied here — but block the
# obvious by reflex, as a backstop.
*.key
*.pem
*.token
.env
.credentials.json
settings.local.json
*.log

# Backlog working state. `.claude/.jarrin.yml` is committed config and must stay
# tracked — only the transient plan/todo files below are ignored.
.claude/plans/
.claude/todo/
