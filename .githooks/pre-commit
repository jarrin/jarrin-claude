#!/usr/bin/env sh
# Pre-commit checks: hook unit tests + secret scan (gitleaks). Version-controlled.
# Enable per clone with:  git config core.hooksPath .githooks

# 1. Unit tests for the SessionStart rule loader (stdlib python, no deps).
if command -v python3 >/dev/null 2>&1; then
  if [ -f bin/claude/test_session_start.py ]; then
    echo "Running session-start hook tests..." >&2
    if ! python3 -m unittest discover -s bin/claude -p 'test_*.py' >&2; then
      echo "" >&2
      echo "Hook unit tests failed. Commit aborted." >&2
      echo "  To bypass (NOT recommended): git commit --no-verify" >&2
      exit 1
    fi
  fi
else
  echo "python3 not installed - skipping hook unit tests." >&2
fi

# 2. Secret scan.
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks not installed - skipping secret scan." >&2
  echo "  Install: https://github.com/gitleaks/gitleaks" >&2
  exit 0
fi

gitleaks git --staged --redact --no-banner -v
status=$?
if [ "$status" -ne 0 ]; then
  echo "" >&2
  echo "gitleaks found potential secrets in staged changes. Commit aborted." >&2
  echo "  Review the findings above." >&2
  echo "  To bypass (NOT recommended): git commit --no-verify" >&2
fi
exit "$status"
