#!/usr/bin/env sh
# Pre-commit checks: claudjar CLI gates + secret scan (gitleaks). Version-controlled.
# Enable per clone with:  git config core.hooksPath .githooks

# 1. claudjar CLI gate: lint + typecheck + Vitest + build.
#    dist/ is a gitignored build artifact, so there is no staleness check — the
#    build runs purely to prove the source still bundles.
if command -v pnpm >/dev/null 2>&1 && [ -f package.json ]; then
  echo "Running claudjar checks (pnpm check)..." >&2
  if ! pnpm run --silent check >&2; then
    echo "" >&2
    echo "claudjar checks failed. Commit aborted." >&2
    echo "  Fix the reported lint / type / test / build failure." >&2
    echo "  To bypass (NOT recommended): git commit --no-verify" >&2
    exit 1
  fi
else
  echo "pnpm not installed - skipping claudjar checks." >&2
fi

# 2. Secret scan.
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks not installed - skipping secret scan." >&2
  echo "  Install: https://github.com/gitleaks/gitleaks" >&2
  exit 0
fi

gitleaks git --staged --redact --no-banner -v
status=$?
if [ "$status" -ne 0 ]; then
  echo "" >&2
  echo "gitleaks found potential secrets in staged changes. Commit aborted." >&2
  echo "  Review the findings above." >&2
  echo "  To bypass (NOT recommended): git commit --no-verify" >&2
fi
exit "$status"
