#!/usr/bin/env python3
"""Write a file-backend todo: ``<dir>/<N>-<kebab-title>.md`` with the next number.

The number continues from the highest existing ``N-`` prefix in ``--dir`` (so files sort
in creation order: ``1-refactor.md``, ``2-implement-x.md``, …). The title is kebab-cased
for the filename but kept verbatim in the file's frontmatter and heading. The body is read
from ``--body`` or, if omitted, from stdin. Prints the created path.

Standard library only, so it runs anywhere a ``python3`` interpreter exists.
"""

from __future__ import annotations

import argparse
import datetime
import os
import re
import sys


def kebab(text: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", text.strip().lower()).strip("-")
    return slug or "todo"


def next_number(directory: str) -> int:
    highest = 0
    if os.path.isdir(directory):
        for name in os.listdir(directory):
            match = re.match(r"(\d+)-", name)
            if match:
                highest = max(highest, int(match.group(1)))
    return highest + 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Create a numbered file-backend todo.")
    parser.add_argument("--dir", default=".claude/todo", help="output directory")
    parser.add_argument("--title", required=True, help="human title (kept verbatim)")
    parser.add_argument("--body", default=None, help="body text; if omitted, read stdin")
    args = parser.parse_args()

    body = args.body
    if body is None:
        body = "" if sys.stdin.isatty() else sys.stdin.read()
    body = body.strip()

    os.makedirs(args.dir, exist_ok=True)
    number = next_number(args.dir)
    path = os.path.join(args.dir, "{}-{}.md".format(number, kebab(args.title)))
    today = datetime.date.today().isoformat()

    content = "---\ntitle: {title}\nstatus: open\ncreated: {date}\n---\n\n# {title}\n".format(
        title=args.title, date=today
    )
    if body:
        content += "\n" + body + "\n"

    # `x` mode: never clobber an existing todo if two land on the same number.
    with open(path, "x", encoding="utf-8") as handle:
        handle.write(content)

    print(path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
