#!/usr/bin/env sh
# SessionEnd hook launcher. This file is deployed to ~/.claude/bin/ (bin/claude
# is symlinked there) and registered in claude/settings.json. It is a thin
# launcher — all logic lives in the Node bundle at <repo>/dist/claudjar.js, which
# this resolves relative to its own real path (following the symlink) and invokes
# with the `session-end` subcommand. The hook JSON payload is passed on stdin.
set -eu
self="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
repo="$(CDPATH= cd -- "$(dirname -- "$self")/../.." && pwd)"
exec node "$repo/dist/claudjar.js" session-end "$@"
