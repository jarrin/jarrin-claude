#!/usr/bin/env sh
# SessionStart hook launcher. This file is deployed to ~/.claude/bin/ (bin/claude
# is symlinked there) and registered in claude/settings.json. It is a thin
# launcher — all logic lives in the Node bundle at <repo>/dist/claudjar.js, which
# this resolves relative to its own real path (following the symlink) and invokes
# with the `session-start` subcommand. The hook JSON payload is passed on stdin.
#
# dist/ is a build artifact and is NOT committed, so a fresh clone has no bundle
# until `pnpm build` runs. This hook is registered globally and fires in EVERY
# repo, so a missing bundle warns on stderr and exits 0 — a session then starts
# without its injected rules, rather than every session on the machine failing.
set -eu
self="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
repo="$(CDPATH= cd -- "$(dirname -- "$self")/../.." && pwd)"
bundle="$repo/dist/claudjar.js"
if [ ! -f "$bundle" ]; then
  echo "claudjar: bundle not built ($bundle); skipping rule injection." >&2
  echo "  Run: cd $repo && pnpm install && pnpm build" >&2
  exit 0
fi
exec node "$bundle" api session-start "$@"
