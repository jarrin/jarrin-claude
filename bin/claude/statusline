#!/usr/bin/env sh
# statusLine launcher. This file is deployed to ~/.claude/bin/ (bin/claude is
# symlinked there) and registered in claude/settings.json under `statusLine`. It
# is a thin launcher — all logic lives in the Node bundle at <repo>/dist/claudjar.js,
# which this resolves relative to its own real path (following the symlink) and
# invokes with the `statusline` subcommand. The Status JSON payload is passed on
# stdin; the single-line statusline is written to stdout.
set -eu
self="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
repo="$(CDPATH= cd -- "$(dirname -- "$self")/../.." && pwd)"
exec node "$repo/dist/claudjar.js" statusline "$@"
