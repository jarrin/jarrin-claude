#!/usr/bin/env sh
# Repo-local launcher for the claudjar CLI, for use before the standalone binary
# is on PATH (a fresh clone, or a checkout you do not want to install from).
#
# Prefers the standalone binary at dist/build/claudjar and falls back to running
# the CJS bundle under node. Neither is committed — `dist/` is a build artifact —
# so the guard below explains how to produce one rather than letting node fail
# with a bare MODULE_NOT_FOUND. For everyday use run `pnpm run ensurepath` once,
# which builds and links `claudjar` into ~/.local/bin.
set -eu
self="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
repo="$(CDPATH= cd -- "$(dirname -- "$self")/.." && pwd)"
binary="$repo/dist/build/claudjar"
bundle="$repo/dist/claudjar.cjs"
if [ -x "$binary" ]; then
  exec "$binary" "$@"
fi
if [ -f "$bundle" ]; then
  exec node "$bundle" "$@"
fi
echo "claudjar: not built ($binary)." >&2
echo "  Run: cd $repo && pnpm install && pnpm run build" >&2
exit 1
